{
    "name": "lumen/php",
    "description": "LUMEN binary protocol — PHP binding",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lumen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lumen\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "test": "phpunit tests --display-deprecations",
        "e2e": "php tests/e2e_test.php"
    }
}
