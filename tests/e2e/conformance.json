    "hyb128": {
      "description": "Hyb128 variable-length integer encoding.",
      "tests": [
        {"name": "hyb128_encode_zero", "input": 0, "expected_hex": "00", "expected_header_len": 1},
        {"name": "hyb128_encode_63", "input": 63, "expected_hex": "3f", "expected_header_len": 1},
        {"name": "hyb128_encode_64", "input": 64, "expected_hex": "4040", "expected_header_len": 2},
        {"name": "hyb128_encode_16383", "input": 16383, "expected_hex": "7fff", "expected_header_len": 2},
        {"name": "hyb128_encode_16384", "input": 16384, "expected_hex": "80004000", "expected_header_len": 4},
        {"name": "hyb128_encode_u32_max", "input": 4294967295, "expected_hex": "80ffffff", "expected_header_len": 4},
        {"name": "hyb128_decode_incomplete", "input_hex": "80", "expected": null},
