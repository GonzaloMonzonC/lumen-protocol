{
  "$schema": "conformance.json",
  "protocol": "LUMEN/1.0",
  "spec_version": "v0.1.0",
  "description": "LUMEN protocol conformance test suite — cross-implementation verification vectors. Values verified against the actual Hyb128 encoder (1/3/5B modes: short/u16/u32/LEB128).",
  "generated": "2026-06-17",
  "implementations": {
    "rust": {
      "path": "implementations/rust/",
      "version": "0.1.0",
      "test_runner": "cargo test"
    },
    "typescript": {
      "path": "implementations/typescript/",
      "version": "0.1.0",
      "test_runner": "npm test"
    }
  },
  "categories": {
    "hyb128": {
      "description": "Hyb128 variable-length integer encoding — 2-bit mode prefix: 00=short(6bit), 10=u16, 11=u32, 01=LEB128.",
      "tests": [
        {"name": "hyb128_encode_zero", "input": 0, "expected_hex": "00", "expected_header_len": 1},
        {"name": "hyb128_encode_63", "input": 63, "expected_hex": "3f", "expected_header_len": 1},
        {"name": "hyb128_encode_64", "input": 64, "expected_hex": "804000", "expected_header_len": 3},
        {"name": "hyb128_encode_16383", "input": 16383, "expected_hex": "80ff3f", "expected_header_len": 3},
        {"name": "hyb128_encode_16384", "input": 16384, "expected_hex": "800040", "expected_header_len": 3},
        {"name": "hyb128_encode_u32_max", "input": 4294967295, "expected_hex": "c0ffffffff", "expected_header_len": 5},
        {"name": "hyb128_decode_incomplete", "input_hex": "80", "expected": null},
        {"name": "hyb128_roundtrip_fuzz", "type": "sweep", "values": [0,1,63,64,127,255,16383,16384,65535,65536,1048575,1048576,4294967295]}
      ]
    },
    "dict": {
      "description": "Dictionary compression — 128 static + 127 LRU-adaptive session slots.",
      "tests": [
        {"name": "dict_static_core_keys", "pairs": [
          {"key":"tool","id":"0x00"},{"key":"arguments","id":"0x01"},{"key":"result","id":"0x02"},{"key":"error","id":"0x03"},{"key":"id","id":"0x04"}
        ]},
        {"name": "dict_static_llm_keys", "pairs": [
          {"key":"model","id":"0x40"},{"key":"temperature","id":"0x42"},{"key":"max_tokens","id":"0x43"},{"key":"top_p","id":"0x47"}
        ]},
        {"name": "dict_no_duplicate_keys", "type": "invariant"},
        {"name": "dict_id_raw_sentinel", "expected_id_raw": "0xFF"},
        {"name": "dict_fast_lookup_matches_linear", "type": "sweep", "range": "0x00..0x7F"},
        {"name": "dict_session_register_and_lookup", "type": "behavioral"},
        {"name": "dict_lru_touch_updates_metadata", "type": "invariant"},
        {"name": "dict_lru_evict_least_recent", "type": "behavioral", "expected_lru_id": "0x80", "expected_len_after_evict": 126},
        {"name": "dict_lru_register_lru_auto_assign", "type": "behavioral"},
        {"name": "dict_lru_touch_out_of_range_noop", "type": "invariant"},
        {"name": "dict_clear_resets_all_state", "type": "invariant"}
      ]
    },
    "compress": {
      "description": "JSON Value to compact binary compression (lossless roundtrip). Note: whole-number floats are canonicalized to TAG_INT for cross-language interop.",
      "tests": [
        {"name": "compress_null", "value": null, "expected_tags": ["TAG_NULL"], "expected_hex_prefix": "e0"},
        {"name": "compress_bool_true", "value": true, "expected_tags": ["TAG_BOOL"], "expected_hex_prefix": "e101"},
        {"name": "compress_bool_false", "value": false, "expected_tags": ["TAG_BOOL"], "expected_hex_prefix": "e100"},
        {"name": "compress_int_small", "value": 42, "expected_tags": ["TAG_INT"], "expected_hex_prefix": "e3"},
        {"name": "compress_int_negative", "value": -100, "expected_tags": ["TAG_INT"], "expected_hex_prefix": "e3"},
        {"name": "compress_float_pi", "value": 3.141592653589793, "expected_tags": ["TAG_FLOAT"], "expected_hex_prefix": "e2"},
        {"name": "compress_float_zero", "value": 0.0, "expected_tags": ["TAG_INT"], "note": "Canonicalized: whole-number float → TAG_INT"},
        {"name": "compress_string_dict_hit", "value": "tool", "expected_tags": ["TAG_STR_DICT"], "expected_hex": "e400"},
        {"name": "compress_string_raw", "value": "custom_not_in_dict_xyz", "expected_tags": ["TAG_STR_RAW"]},
        {"name": "compress_array_empty", "value": [], "expected_tags": ["TAG_ARRAY"]},
        {"name": "compress_array_mixed", "value": [null, true, 42, "text", 3.14], "expected_tags": ["TAG_ARRAY"]},
        {"name": "compress_object_empty", "value": {}, "expected_tags": ["TAG_OBJECT"]},
        {"name": "compress_object_dict_keys", "value": {"tool":"search","arguments":{"query":"hello"}}, "expected_tags": ["TAG_OBJECT"]},
        {"name": "compress_roundtrip_all_vectors", "type": "sweep", "source": "shared_vectors.json"},
        {"name": "compress_malformed_input", "type": "invariant", "inputs_hex": ["","ff","e1","e6ff","e7ff"]},
        {"name": "compress_compressed_size_accurate", "type": "invariant", "source": "shared_vectors.json"}
      ]
    },
    "frame": {
      "description": "Frame building, parsing, type constants — the LUMEN wire format.",
      "tests": [
        {"name": "frame_type_constants", "types": {
          "0x01":"REQUEST","0x02":"RESPONSE","0x03":"NOTIFY","0x04":"STREAM_DATA",
          "0x05":"SCHEMA_PATCH","0x06":"STREAM_INIT","0x07":"DICT_SYNC","0x08":"DISCOVER",
          "0x09":"MUX","0x0A":"HEARTBEAT","0x0B":"TRANSPORT_INIT","0x0C":"TRANSPORT_ACK",
          "0x0D":"BATCH","0x0E":"FLOW_CTL","0x0F":"PROBE","0x10":"PROBE_ACK"
        }},
        {"name": "frame_flag_constants", "flags": {
          "0x01":"COMPRESSED","0x02":"ENCRYPTED","0x04":"PRIORITY","0x08":"FRAGMENTED"
        }},
        {"name": "frame_build_parse_roundtrip", "type": "behavioral"},
        {"name": "frame_build_size_consistency", "type": "invariant", "payload_lengths": [0,1,63,64,1000,65535,65536]},
        {"name": "frame_parse_incomplete", "inputs_hex": ["","01","0100"], "expected": "Incomplete"},
        {"name": "frame_parse_incomplete_payload", "type": "behavioral"},
        {"name": "frame_type_name_coverage", "type": "sweep", "range": "0x01..0x10"},
        {"name": "frame_flags_accessors", "type": "behavioral"}
      ]
    }
  },
  "cross_impl_results": {
    "description": "Results from running this suite against each implementation. Run 'python tests/e2e/run_e2e.py' and 'npm test' to populate.",
    "rust": {"passed": null, "failed": null, "last_run": null, "note": "Run 'cargo test' to populate"},
    "typescript": {"passed": null, "failed": null, "last_run": null, "note": "Run 'npm test' to populate"}
  }
}
