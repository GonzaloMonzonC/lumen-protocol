      ]
    },
    "dict": {
      "description": "Dictionary compression — 128 static + 127 LRU-adaptive session slots.",
      "tests": [
        {"name": "dict_static_core_keys", "pairs": [
          {"key":"tool","id":"0x00"},{"key":"arguments","id":"0x01"},{"key":"result","id":"0x02"},{"key":"error","id":"0x03"},{"key":"id","id":"0x04"}
        ]},
        {"name": "dict_static_llm_keys", "pairs": [
          {"key":"model","id":"0x40"},{"key":"temperature","id":"0x42"},{"key":"max_tokens","id":"0x43"},{"key":"top_p","id":"0x47"}
        ]},
        {"name": "dict_no_duplicate_keys", "type": "invariant"},
        {"name": "dict_id_raw_sentinel", "expected_id_raw": "0xFF"},
        {"name": "dict_fast_lookup_matches_linear", "type": "sweep", "range": "0x00..0x7F"},
        {"name": "dict_session_register_and_lookup", "type": "behavioral"},
        {"name": "dict_lru_touch_updates_metadata", "type": "invariant"},
        {"name": "dict_lru_evict_least_recent", "type": "behavioral", "expected_lru_id": "0x80", "expected_len_after_evict": 126},
        {"name": "dict_lru_register_lru_auto_assign", "type": "behavioral"},
        {"name": "dict_lru_touch_out_of_range_noop", "type": "invariant"},
        {"name": "dict_clear_resets_all_state", "type": "invariant"}
      ]
    },
    "compress": {
      "description": "JSON Value to compact binary compression (lossless roundtrip).",
      "tests": [
        {"name": "compress_null", "value": null, "expected_tags": ["TAG_NULL"], "expected_hex_prefix": "e0"},
        {"name": "compress_bool_true", "value": true, "expected_tags": ["TAG_BOOL"], "expected_hex_prefix": "e101"},
        {"name": "compress_bool_false", "value": false, "expected_tags": ["TAG_BOOL"], "expected_hex_prefix": "e100"},
        {"name": "compress_int_small", "value": 42, "expected_tags": ["TAG_INT"], "expected_hex_prefix": "e3"},
        {"name": "compress_int_negative", "value": -100, "expected_tags": ["TAG_INT"], "expected_hex_prefix": "e3"},
        {"name": "compress_float_pi", "value": 3.141592653589793, "expected_tags": ["TAG_FLOAT"], "expected_hex_prefix": "e2"},
        {"name": "compress_string_dict_hit", "value": "tool", "expected_tags": ["TAG_STR_DICT"], "expected_hex": "e400"},
        {"name": "compress_string_raw", "value": "custom_not_in_dict_xyz", "expected_tags": ["TAG_STR_RAW"]},
        {"name": "compress_array_empty", "value": [], "expected_tags": ["TAG_ARRAY"]},
        {"name": "compress_array_mixed", "value": [null, true, 42, "text", 3.14], "expected_tags": ["TAG_ARRAY"]},
        {"name": "compress_object_empty", "value": {}, "expected_tags": ["TAG_OBJECT"]},
        {"name": "compress_object_dict_keys", "value": {"tool":"search","arguments":{"query":"hello"}}, "expected_tags": ["TAG_OBJECT"]},
        {"name": "compress_roundtrip_all_vectors", "type": "sweep", "source": "shared_vectors.json"},
        {"name": "compress_malformed_input", "type": "invariant", "inputs_hex": ["","ff","e1","e6ff","e7ff"]},
        {"name": "compress_compressed_size_accurate", "type": "invariant", "source": "shared_vectors.json"}
      ]
    },
